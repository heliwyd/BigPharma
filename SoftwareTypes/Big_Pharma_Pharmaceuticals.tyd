                }
                {
                    Name        "Automated Dosage Filling"
                    Description "Improves consistency of pill and injection production"
                    DevTime     4
                    Level       1
                    CodeArt     1
                    Submarkets  [ 1; 2; 0 ]
                }
                {
                    Name        "Quality Control Sampling"
                    Description "Detects defective batches before distribution"
                    DevTime     5
                    Level       2
                    CodeArt     0.75
                    Submarkets  [ 1; 1; 1 ]
                }
                {
                    Name        "Cold Chain Distribution"
                    Description "Maintains temperature-sensitive compounds during shipping"
                    DevTime     6
                    Level       2
                    CodeArt     0.75
                    Submarkets  [ 0; 2; 1 ]
                }
                {
                    Name        "Mass Production Scaling"
                    Description "Increases output efficiency but raises regulatory scrutiny"
                    DevTime     8
                    Level       2
                    CodeArt     0.8
                    Submarkets  [ 1; 1; 1 ]
                }
                {
                    Name        "Regulatory Batch Auditing"
                    Description "Enables inspection risk reduction and compliance reporting"
                    DevTime     10
                    Level       3
                    CodeArt     0.6
                    Submarkets  0
                    RunType     Local
                    Script_EndOfDay "
                    if (Product.GetVar(\"BatchAuditing\", true))
                    {
                        Product.Bugs = Max(0, Product.Bugs - Product.Userbase * 0.000002);
                    }
                    "
                    
                    Script_OnRelease "
                    Product.PutVar(\"BatchAuditing\", true);
                    "
                }
            ]
