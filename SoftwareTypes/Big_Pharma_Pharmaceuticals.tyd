	Features
		[
			{
			Name		"Bioengineering"
			Spec		Bio-Engineer
			DevTime		10
			CodeArt		0.85
			Submarkets	[ 1; 1; 1 ]
			Features
				[
					{
					Name		"Molecular Synthesis"
					Description "Simulates chemical compound formation and reaction pathways."
					DevTime		6
					Level		1
					CodeArt		1
					Submarkets	[ 1; 1; 1 ]
					}
					{
