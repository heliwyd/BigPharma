					DevTime		5
					Level		1
					CodeArt		1
					Submarkets	[ 1; 1; 1 ]
					}
					{
					Name		"Quality Assurance"
					Description	"Standardized testing procedures for safety and effectiveness."
					DevTime		6
					Level		1
					CodeArt		0.9
					Submarkets	[ 1; 1; 1 ]
					}
					{
					Name		"Targeted Mechanisms"
					Description	"Design compounds that interact with specific systems."
					DevTime		8
					Level		2
					CodeArt		0.9
					Submarkets	[ 1; 2; 1 ]
					}
					{
					Name		"Bioavailability Engineering"
					Description "Optimizes how efficiently compounds are absorbed by the body."
					DevTime		7
					Level		2
					CodeArt		0.75
					Submarkets	[ 1; 2; 1 ]
					}
					{
        			Name		"Controlled Release Systems"
        			Description "Controls timing and release rate of active compounds in the body"
        			DevTime		7
        			Level		2
        			CodeArt		0.75
        			Submarkets	[ 1; 1; 2 ]
        			}
        			{
        			Name		"Manufacturing Purity Scaling"
        			Description "Maintains compound purity across mass production processes"
        			DevTime		8
        			Level		2
        			CodeArt		0.8
        			Submarkets	[ 1; 1; 2 ]
        			}
        			{
        			Name		"Human Trial Simulation"
        			Description "Simulates clinical trial outcomes including risk and side effects"
        			DevTime		14
        			Level		3
        			CodeArt		0.5
        			Submarkets	0
        			Unlock		1990
        			RunType     Local
        			
        			Script_OnRelease
                    "
                    Product.PutVar(\"HumanTrials\", true);
                    "
                    
                    Script_EndOfDay
                    "
                    if (Product.GetVar(\"HumanTrials\", false))
                    {
                    	Product.Bugs = Max(0, Product.Bugs - Product.Userbase * 0.000001);
                    
                    	if (Random() * Product.Userbase > 1500000 * Product.Category.Popularity)
                    	{
                    		LaunchLawsuit(\"UnapprovedHumanTrials\", Product.Sum, 0.8);
                    
                    		Product.DevCompany.AddFans(-Product.Userbase * 0.2, Product.Category);
                    		Product.ChangeUserbase(Product.Userbase * 0.3);
                    
                    		Product.PutVar(\"HumanTrials\", false);
                    
                    		AddPopup(\"Human trials controversy detected.\", 0.8, \"Exclamation\", Issue);
                    	}
                    }
                    "
        			}
				]
			}
			{
            Name        "Dependency Check"
            Spec        Artist
            DevTime     1
            CodeArt     1
            Submarkets  [ 1; 1; 1 ]
            Dependencies [ "Lab Systems" ]
            }
			{
            Name        "Medical Manufacturing"
